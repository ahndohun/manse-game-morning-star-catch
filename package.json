{
  "name": "manse-game-morning-star-catch",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "overrides": {
    "postcss": "8.5.20"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "node scripts/sync-runtime-assets.mjs",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "validate:content": "manse validate . --json",
    "validate:release": "node scripts/check-release.mjs",
    "validate": "npm run typecheck && npm run test && npm run validate:content"
  },
  "dependencies": {
    "@manse/runtime-web": "file:vendor/manse-runtime-web",
    "@manse/schema": "file:vendor/manse-schema",
    "@mediapipe/tasks-vision": "0.10.35",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@manse/cli": "file:vendor/manse-cli",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  }
}
